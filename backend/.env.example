# Copy this file to .env and fill values for production
PORT=5000
# Use a managed MongoDB (Atlas) connection string in production
MONGO_URI=your_production_mongo_uri_here
# Strong random secrets for JWT
JWT_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_strong_random_refresh_secret
# Comma-separated allowed origins (add your deployed frontend URL)
CORS_ORIGINS=https://my-tailor-ch9n.vercel.app
# Optional: FRONTEND_URL used by app if you prefer
FRONTEND_URL=https://my-tailor-ch9n.vercel.app
